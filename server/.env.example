# LivePage server configuration (copy to .env; .env is gitignored)

PORT=3000

# Upload / content hosting
UPLOAD_MAX_MB=50
DATA_DIR=data

# Share-link token time-to-live (hours)
TOKEN_TTL_H=24

# Reclaim empty rooms after N minutes of inactivity
ROOM_IDLE_MIN=120

# Voice: mesh (MVP) | livekit (v1.1)
VOICE_PROVIDER=mesh

# Optional self-hosted TURN (coturn) for symmetric-NAT users
# TURN_URL=turn:host:3478
# TURN_USER=
# TURN_CRED=

# Dev-only CORS origin (nginx serves same-origin in prod)
CORS_ORIGIN=*
